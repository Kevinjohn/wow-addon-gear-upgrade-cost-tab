package-as: GearUpgradeCostTab

enable-nolib-creation: no

# Repo-only files that should never ship inside the addon zip.
ignore:
  - .release
  - .github
  - .gitignore
  - .gitattributes
  - .luacheckrc
  - .pkgmeta
  - scripts
  - tests
  - docs
  - README.md
  - README-dev.md
  - CONTRIBUTING.md
  - SECURITY.md
  - CODE_OF_CONDUCT.md
  - _wow-Addon-Publishing-Readiness.md
  - .DS_Store
  # CHANGELOG.md is intentionally not ignored: manual-changelog (below) ships
  # this curated file as the changelog instead of a git-log dump.

# Ship our curated changelog instead of the packager's git-log dump.
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
