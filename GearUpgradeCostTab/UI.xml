<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

	<Script file="UI.lua"/>

	<!-- Accordion section header, styled like the Currency tab's headers -->
	<Button name="GearUpgradeCostTabHeaderTemplate" inherits="ListHeaderThreeSliceTemplate" mixin="GearUpgradeCostTabHeaderMixin" virtual="true">
		<Scripts>
			<OnLoad method="OnLoadHeader" inherit="append"/>
		</Scripts>
	</Button>

	<!-- One equipped item: item level, slot, upgrade track, crest costs.
	     Item level leads so it lines up with the bag-row templates below.
	     The track column is two regions so a long localized track name
	     ("Искатель приключений") truncates with an ellipsis while the rank
	     ("4/6") stays visible. TotalCost/NextCost/TrackRank are declared
	     before Track because each right anchor references the previous
	     region (regions resolve in document order). -->
	<Button name="GearUpgradeCostTabRowTemplate" mixin="GearUpgradeCostTabRowMixin" virtual="true">
		<Size y="22"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="ItemLevel" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="30" y="0"/>
					<Anchors>
						<Anchor point="LEFT" x="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="SlotName" inherits="GameFontHighlightSmall" justifyH="LEFT">
					<Size x="68" y="0"/>
					<Anchors>
						<Anchor point="LEFT" x="60"/>
					</Anchors>
				</FontString>
				<FontString parentKey="TotalCost" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="44" y="0"/>
					<Anchors>
						<Anchor point="RIGHT" x="-4"/>
					</Anchors>
				</FontString>
				<FontString parentKey="NextCost" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="44" y="0"/>
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TotalCost" relativePoint="LEFT" x="-4"/>
					</Anchors>
				</FontString>
				<FontString parentKey="TrackRank" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="30" y="0"/>
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.NextCost" relativePoint="LEFT" x="-6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Track" inherits="GameFontHighlightSmall" justifyH="LEFT" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" x="140"/>
						<Anchor point="RIGHT" relativeKey="$parent.TrackRank" relativePoint="LEFT" x="-4"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD" setAllPoints="true"/>
		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Button>

	<!-- One bag item: item level, slot, then the item name sitting where the
	     equipped rows show the upgrade track (same small font, so the columns
	     read as one table). TotalCost/NextCost are declared before Name
	     because Name's right anchor references NextCost (regions resolve in
	     document order). -->
	<Button name="GearUpgradeCostTabBagRowTemplate" mixin="GearUpgradeCostTabBagRowMixin" virtual="true">
		<Size y="22"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="ItemLevel" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="30" y="0"/>
					<Anchors>
						<Anchor point="LEFT" x="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="SlotName" inherits="GameFontHighlightSmall" justifyH="LEFT">
					<Size x="68" y="0"/>
					<Anchors>
						<Anchor point="LEFT" x="60"/>
					</Anchors>
				</FontString>
				<FontString parentKey="TotalCost" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="44" y="0"/>
					<Anchors>
						<Anchor point="RIGHT" x="-4"/>
					</Anchors>
				</FontString>
				<FontString parentKey="NextCost" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size x="44" y="0"/>
					<Anchors>
						<Anchor point="RIGHT" relativeKey="$parent.TotalCost" relativePoint="LEFT" x="-4"/>
					</Anchors>
				</FontString>
				<FontString parentKey="Name" inherits="GameFontHighlightSmall" justifyH="LEFT" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" x="140"/>
						<Anchor point="RIGHT" relativeKey="$parent.NextCost" relativePoint="LEFT" x="-8"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD" setAllPoints="true"/>
		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Button>

	<!-- Invisible spacer between sections; actual height comes from the
	     element data via the view's extent calculator in UI.lua -->
	<Frame name="GearUpgradeCostTabSpacerTemplate" virtual="true">
		<Size y="4"/>
	</Frame>

	<!-- Informational row (used by the empty "In Bag" section) -->
	<Frame name="GearUpgradeCostTabNoteTemplate" mixin="GearUpgradeCostTabNoteMixin" virtual="true">
		<Size y="20"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="Text" inherits="GameFontDisableSmall" justifyH="LEFT">
					<Anchors>
						<Anchor point="LEFT" x="10"/>
						<Anchor point="RIGHT" x="-10"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>

	<!-- The 4th character frame subframe; layout mirrors Blizzard's TokenFrame -->
	<Frame name="GearUpgradeCostTabFrame" parent="CharacterFrame" setAllPoints="true" useParentLevel="true" enableMouse="true" mixin="GearUpgradeCostTabMixin" hidden="true" id="4">
		<Frames>
			<Frame parentKey="ScrollBox" inherits="WowScrollBoxList" frameStrata="HIGH">
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.$parent.Inset" x="4" y="-28"/>
					<Anchor point="BOTTOMRIGHT" relativeKey="$parent.$parent.Inset" x="-22" y="2"/>
				</Anchors>
			</Frame>

			<EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar" frameStrata="HIGH">
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" x="5" y="-2"/>
					<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="BOTTOMRIGHT" x="5" y="4"/>
				</Anchors>
			</EventFrame>

			<DropdownButton parentKey="CostModeDropdown" inherits="WowStyle1DropdownTemplate">
				<Anchors>
					<!-- Right edge flush with the list inset below, 4px above it -->
					<Anchor point="BOTTOMRIGHT" relativeKey="$parent.$parent.Inset" relativePoint="TOPRIGHT" x="0" y="4"/>
				</Anchors>
			</DropdownButton>
		</Frames>
		<Layers>
			<Layer level="ARTWORK">
				<!-- Column labels, aligned with the row template's columns.
				     ColItemLevel auto-sizes: Blizzard's localized
				     ITEM_LEVEL_ABBR runs from "St." to "Ур. пр.", and a
				     fixed 30px box would ellipsize the wider ones. -->
				<FontString parentKey="ColItemLevel" inherits="GameFontDisableSmall" justifyH="LEFT">
					<Anchors>
						<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPLEFT" x="10" y="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="ColSlot" inherits="GameFontDisableSmall" justifyH="LEFT">
					<Anchors>
						<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPLEFT" x="64" y="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="ColUpgrade" inherits="GameFontDisableSmall" justifyH="LEFT">
					<Anchors>
						<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPLEFT" x="144" y="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="ColTotalCost" inherits="GameFontDisableSmall" justifyH="RIGHT">
					<Anchors>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" x="-8" y="6"/>
					</Anchors>
				</FontString>
				<FontString parentKey="ColNextCost" inherits="GameFontDisableSmall" justifyH="RIGHT">
					<Anchors>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" x="-56" y="6"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnShow method="OnShow"/>
			<OnHide method="OnHide"/>
			<OnEvent method="OnEvent"/>
		</Scripts>
	</Frame>
</Ui>
